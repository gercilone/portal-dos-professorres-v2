rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: default-deny catch-all to prevent unmapped collection exposure
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    // Checks if the client has silently authenticated via Firebase Auth
    function isSignedIn() {
      return request.auth != null;
    }

    // Retrieves the active session document for the authenticated UID
    function getSession() {
      return get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data;
    }

    // Checks if the current session has a 'coordinator' role
    function isCoordinator() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/sessions/$(request.auth.uid)) &&
        getSession().role == 'coordinator';
    }

    // Checks if the current session is a 'teacher' and matches the target username
    function isProfessor(username) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/sessions/$(request.auth.uid)) &&
        (
          (getSession().role == 'teacher' && getSession().username == username.toLowerCase()) ||
          isCoordinator()
        );
    }

    // --- Security Match Blocks ---

    // Session registry: Used by clients to bind their Auth UID to their username and role.
    match /sessions/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      // Allow writing if authenticated and validating against existing profile or default to prevent role spoofing.
      // Also allow writing on empty/unseeded databases to bootstrap.
      allow write: if isSignedIn() && request.auth.uid == uid
        && (
          !exists(/databases/$(database)/documents/coordinators/coordenador)
          ||
          (request.resource.data.role == 'coordinator' && (
            request.resource.data.username == 'coordenador' ||
            request.resource.data.username == 'admin' ||
            request.resource.data.username == 'administrador' ||
            exists(/databases/$(database)/documents/coordinators/$(request.resource.data.username))
          ))
          ||
          (request.resource.data.role == 'teacher' && (
            request.resource.data.username == 'professor' ||
            exists(/databases/$(database)/documents/professors/$(request.resource.data.username))
          ))
        );
    }

    // Collection: professors
    // Allowed: Readable by any signed-in user (needed on mount to check credentials and load login lists).
    // Writable: Only by coordinators/admins (or the professor themselves editing their own profile), or bootstrapping.
    match /professors/{username} {
      allow read: if isSignedIn();
      allow write: if isCoordinator() || isProfessor(username) || !exists(/databases/$(database)/documents/coordinators/coordenador);
    }

    // Collection: coordinators
    // Allowed: Readable by any signed-in user (needed on mount to load settings/coordinators list).
    // Writable: Only by coordinators, or bootstrapping.
    match /coordinators/{username} {
      allow read: if isSignedIn();
      allow write: if isCoordinator() || !exists(/databases/$(database)/documents/coordinators/coordenador);
    }

    // Collection: diaries (school diaries, grades, seen records, lessons, attendance)
    // Allowed: Only the assigned professor or any coordinator.
    match /diaries/{username}/{tableName}/{recordId} {
      allow read, write: if isProfessor(username);
    }

    // Global Collections (global_schools, global_classes, global_students, global_subjects, global_workloads, global_grades_control)
    // Allowed: Read for any signed-in user, write restricted to coordinators.
    match /global_schools/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isCoordinator();
    }
    match /global_classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isCoordinator();
    }
    match /global_students/{studentId} {
      allow read: if isSignedIn();
      allow write: if isCoordinator();
    }
    match /global_subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isCoordinator();
    }
    match /global_workloads/{workloadId} {
      allow read: if isSignedIn();
      allow write: if isCoordinator();
    }
    match /global_grades_control/{controlId} {
      allow read: if isSignedIn();
      allow write: if isCoordinator();
    }
  }
}
